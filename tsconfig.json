{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/core/sources-browser.ts", "src/browser.ts", "vite.config.ts"]
}
